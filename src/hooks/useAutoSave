import { useState, useEffect, useRef, useCallback } from 'react';
import { base44 } from '@/api/base44Client';
import { toast } from 'sonner';

export function useAutoSave(projectId, field, value, delay = 1000) {
  const [saving, setSaving] = useState(false);
  const [saved, setSaved] = useState(false);
  const saveTimer = useRef(null);

  useEffect(() => {
    if (!projectId || value === undefined) return;

    clearTimeout(saveTimer.current);
    setSaving(true);

    saveTimer.current = setTimeout(async () => {
      try {
        const updated = await base44.entities.PublishingProject.update(projectId, { [field]: value });
        setSaving(false);
        setSaved(true);
        setTimeout(() => setSaved(false), 2000);
      } catch (error) {
        console.error('Auto-save failed:', error);
        setSaving(false);
        toast.error('保存に失敗しました');
      }
    }, delay);

    return () => clearTimeout(saveTimer.current);
  }, [projectId, field, value, delay]);

  return { saving, saved };
}

export function useDebouncedSave(projectId, updates, delay = 1000) {
  const [saving, setSaving] = useState(false);
  const [saved, setSaved] = useState(false);
  const saveTimer = useRef(null);

  const triggerSave = useCallback((newUpdates) => {
    if (!projectId) return;

    clearTimeout(saveTimer.current);
    setSaving(true);

    saveTimer.current = setTimeout(async () => {
      try {
        const updated = await base44.entities.PublishingProject.update(projectId, newUpdates);
        setSaving(false);
        setSaved(true);
        setTimeout(() => setSaved(false), 2000);
        return updated;
      } catch (error) {
        console.error('Auto-save failed:', error);
        setSaving(false);
        toast.error('保存に失敗しました');
        return null;
      }
    }, delay);
  }, [projectId, delay]);

  useEffect(() => {
    if (updates && Object.keys(updates).length > 0) {
      triggerSave(updates);
    }
  }, [updates, triggerSave]);

  return { saving, saved, triggerSave };
}